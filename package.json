{
  "name": "@tembo-io/bitbucket",
  "version": "0.2.1",
  "description": "TypeScript client for the Bitbucket Cloud REST API",
  "type": "module",
  "main": "./lib/index.js",
  "files": [
    "lib/",
    "package.json",
    "LICENSE.md",
    "README.md"
  ],
  "scripts": {
    "generate": "bunx @hey-api/openapi-ts && bun scripts/postprocess-sdk.ts",
    "build": "tsup",
    "tsc": "tsc",
    "postprocess": "bun scripts/postprocess-sdk.ts"
  },
  "license": "MIT",
  "author": {
    "name": "Darren Baldwin",
    "email": "darren@tembo.io"
  },
  "keywords": [
