    "api",
    "client",
    "sdk",
    "rest",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tembo/bitbucket"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.93.1",
    "@types/bun": "latest",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
